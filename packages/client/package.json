{
	"name": "td-antlers-vscode",
	"displayName": "Antlers Language Support",
	"description": "Language server support for the Antlers templating language.",
	"version": "0.0.1",
	"publisher": "josh-theory",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/josh-theory/antlers-vscode"
	},
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Programming Languages",
		"Linters"
	],
	"activationEvents": [
		"onLanguage:antlers"
	],
	"main": "./out/extension",
	"contributes": {
		"languages": [
			{
				"id": "antlers",
				"aliases": [
					"Antlers",
					"antlers"
				],
				"extensions": [
					".antlers.html"
				]
			}
		],
		"configuration": {
			"type": "object",
			"title": "Antlers",
			"properties": {
				"antlers.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 100,
					"description": "Maximum number of diagnostics reported per file."
				},
				"antlers.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces the communication between VS Code and the Antlers language server."
				}
			}
		}
	},
	"dependencies": {
		"vscode-languageclient": "^9.0.1"
	},
	"devDependencies": {
		"@types/vscode": "^1.100.0"
	}
}
