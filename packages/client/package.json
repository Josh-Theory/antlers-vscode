{
	"name": "td-antlers-vscode",
	"displayName": "Antlers Language Support",
	"description": "Language server support for the Antlers templating language.",
	"version": "0.0.1",
	"publisher": "josh-theory",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/josh-theory/antlers-vscode"
	},
	"engines": {
		"vscode": "^1.100.0"
	},
	"categories": [
		"Programming Languages",
		"Linters"
	],
	"activationEvents": [
		"onLanguage:antlers"
	],
	"main": "./dist/extension",
	"contributes": {
		"languages": [
			{
				"id": "antlers",
				"aliases": [
					"Antlers",
					"antlers"
				],
				"extensions": [
					".antlers.html"
				],
				"filenamePatterns": [
					"*.antlers.html"
				]
			}
		],
		"grammars": [
			{
				"language": "antlers",
				"scopeName": "text.html.antlers",
				"path": "./syntaxes/antlers.tmLanguage.json",
				"embeddedLanguages": {
					"meta.embedded.block.antlers": "antlers"
				}
			}
		],
		"semanticTokenTypes": [
			{
				"id": "tag",
				"superType": "type",
				"description": "Antlers tag name."
			}
		],
		"semanticTokenScopes": [
			{
				"language": "antlers",
				"scopes": {
					"comment": [
						"comment.block.antlers"
					],
					"function": [
						"entity.name.function.antlers",
						"support.function.antlers"
					],
					"keyword": [
						"keyword.control.conditional.antlers",
						"keyword.control.antlers"
					],
					"number": [
						"constant.numeric.antlers"
					],
					"operator": [
						"keyword.operator.antlers"
					],
					"string": [
						"string.quoted.double.antlers",
						"string.quoted.single.antlers"
					],
					"tag": [
						"entity.name.tag.html.antlers"
					],
					"variable": [
						"variable.other.readwrite.antlers",
						"entity.name.variable.antlers"
					]
				}
			}
		],
		"configurationDefaults": {
			"[antlers]": {
				"editor.semanticHighlighting.enabled": true
			}
		},
		"configuration": {
			"type": "object",
			"title": "Antlers",
			"properties": {
				"antlers.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 100,
					"description": "Maximum number of diagnostics reported per file."
				},
				"antlers.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces the communication between VS Code and the Antlers language server."
				}
			}
		}
	},
	"dependencies": {
		"vscode-languageclient": "^9.0.1"
	},
	"devDependencies": {
		"@types/vscode": "^1.100.0"
	}
}
