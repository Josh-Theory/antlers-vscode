{
  "grammars": [
    {
      "name": "antlers",
      "camelcase": "Antlers",
      "scope": "source.antlers",
      "path": ".",
      "file-types": [
        "antlers.html"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "injection-regex": "antlers"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Antlers templating language",
    "links": {
      "repository": "https://github.com/josh-theory/antlers-vscode"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
